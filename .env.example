# Telegram Bot Token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (for NLP processing, summarization, and task extraction)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use (default: gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# SQLite database path (default: data/assistant.db)
DATABASE_PATH=data/assistant.db

# Directory where exported files (PDF, iCal) are saved
EXPORTS_DIR=exports

# Timezone for reminders and calendar events (e.g. UTC, America/New_York)
TIMEZONE=UTC

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
